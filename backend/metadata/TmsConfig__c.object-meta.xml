<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>TMS Config</label>
    <pluralLabel>TMS Configs</pluralLabel>
    <nameField>
        <label>TMS Config Name</label>
        <type>AutoNumber</type>
        <displayFormat>TC-{0000}</displayFormat>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <fields>
        <fullName>ShippingMethodRef__c</fullName>
        <label>Shipping Method Ref</label>
        <type>Text</type>
        <length>255</length>
        <required>true</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>CarrierRef__c</fullName>
        <label>Carrier Ref</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>CutoffTime__c</fullName>
        <label>Cutoff Time (HH:MM)</label>
        <type>Text</type>
        <length>5</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>TransitDaysMin__c</fullName>
        <label>Transit Days Min</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>TransitDaysMax__c</fullName>
        <label>Transit Days Max</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OperatingDays__c</fullName>
        <label>Operating Days</label>
        <description>Comma-separated day numbers: 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat, 7=Sun. e.g. "1,2,3,4,5"</description>
        <type>Text</type>
        <length>20</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>IsActive__c</fullName>
        <label>Is Active</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>
</CustomObject>
